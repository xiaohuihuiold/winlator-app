[steam.exe]
BOX64_ENV=WINEARGS=-noshaders -nooverlay -no-browser -nocrashmonitor -no-shared-textures -cef-disable-gpu -cef-disable-gpu-compositing -cef-disable-gpu-sandbox -cef-disable-d3d11 -cef-disable-sandbox -no-cef-sandbox -cef-disable-seccomp-sandbox
BOX64_ENV1=WINEDLLOVERRIDES=gameoverlayrenderer,gameoverlayrenderer64,gameoverlayui.exe,gameoverlayui64.exe,x86launcher.exe,x64launcher.exe,dxsetup.exe=d

[steamwebhelper.exe]
BOX64_DYNAREC_STRONGMEM=1
BOX64_ENV=WINEENV=WINE_D3D_CONFIG=renderer=gdi
BOX64_ENV1=WINEDLLOVERRIDES=d3d8,d3d9,d3d10,d3d10_1,d3d10core,d3d11,ddraw,dxgi=b

[farcry3.exe]
BOX64_ENV=WINEENV=WINE_DO_NOT_OPEN_SC_MANAGER=1

[farcry3_d3d11.exe]
BOX64_ENV=WINEENV=WINE_DO_NOT_OPEN_SC_MANAGER=1

[FarCry4.exe]
BOX64_ENV=WINVERSION=winxp

[watch_dogs.exe]
BOX64_ENV=WINVERSION=winxp

[ffxiiiimg.exe]
BOX64_ENV=WINEARGS=-FullScreenMode=Force -Shadow=512 -Msaa=2

[kof13_win32_Release.exe]
BOX64_ENV1=WINEDLLOVERRIDES=quartz=d

[DXMD.exe]
BOX64_ENV=WINEVMEMMAXSIZE=16384

[rage.exe]
BOX64_ENV=ZINK_CONTEXT_THREADED=0

[rage64.exe]
BOX64_ENV=ZINK_CONTEXT_THREADED=0

[jasp.exe]
BOX64_ENV=MESA_EXTENSION_MAX_YEAR=2002

[MOHAA.exe]
BOX64_ENV=MESA_EXTENSION_MAX_YEAR=2002

[moh_spearhead.exe]
BOX64_ENV=MESA_EXTENSION_MAX_YEAR=2002

[moh_breakthrough.exe]
BOX64_ENV=MESA_EXTENSION_MAX_YEAR=2002

[WolfSP.exe]
BOX64_ENV=MESA_EXTENSION_MAX_YEAR=2002

[DOOMx64.exe]
BOX64_ENV=WINEARGS=+r_renderAPI 1

[ff7remake_.exe]
BOX64_ENV=WINEARGS=-dx11

[Discipl2.exe]
BOX64_ENV=WINEDLLOVERRIDES=ddraw,d3d8=b

[MotoRacer.exe]
BOX64_ENV=WINEDLLOVERRIDES=winmm=n,b

[Chrono Trigger.exe]
BOX64_ENV=WINEDLLOVERRIDES=winegstreamer=d

[witcher3.exe]
BOX64_DYNAREC_STRONGMEM=1

#.NET Framework installers
[*dotnetfx35*]
BOX64_EXIT=1

[*dotnetfx40*]
BOX64_EXIT=1

[*ndp452-kb*]
BOX64_EXIT=1

[*ndp462-kb*]
BOX64_EXIT=1
